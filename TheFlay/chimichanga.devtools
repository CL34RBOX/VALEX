"inline\":[]}}}}]}],[\"$\",\"$Lcb\",null,{\"toggleItems\":[{\"sys\":{\"id\":\"4OoR884MoZClUi4nZycsJE\"},\"contentCollection\":{\"items\":[{\"sys\":{\"id\":\"63AR8trPcjNbK8HwYQnNyL\"},\"accordionLabelRte\":{\"json\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Is Chime an online bank?\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"links\":{\"entries\":{\"inline\":[]}}},\"accordionCopy\":{\"json\":{\"nodeType\":\"document\",\"data\":{},\"content\":[{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Chime is not a bank, but a financial technology company. We partner with The Bancorp Bank, N.A. and Stride Bank, N.A., Members FDIC, which are both FDIC-insured.\",\"marks\":[],\"data\":{}}]}]},\"links\":{\"entries\":{\"inline\":[],\"hyperlink\":[]}}},\"sectionName\":null},{\"sys\":{\"id\":\"VHiFEBXXlmxwTu2edSp6v\"},\"accordionLabelRte\":{\"json\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"How do you open an account online through Chime?\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"links\":{\"entries\":{\"inline\":[]}}},\"accordionCopy\":{\"json\":{\"nodeType\":\"document\",\"data\":{},\"content\":[{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Apply in minutes on chime.com or download the Chime mobile app (\",\"marks\":[],\"data\":{}},{\"nodeType\":\"hyperlink\",\"data\":{\"uri\":\"https://play.google.com/store/apps/details?id=com.onedebit.chime\u0026hl=en_US\"},\"content\":[{\"nodeType\":\"text\",\"value\":\"Google Play\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"text\",\"value\":\" or \",\"marks\":[],\"data\":{}},{\"nodeType\":\"hyperlink\",\"data\":{\"uri\":\"https://apps.apple.com/us/app/chime-mobile-banking/id836215269\"},\"content\":[{\"nodeType\":\"text\",\"value\":\"Apple App Store\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"text\",\"value\":\").\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"You must be at least 18 years old, and you’ll need your Social Security number, email address, and a valid U.S. address.\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Set Up Banking\u2028\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Once approved, you can connect your existing bank account to transfer funds or set up direct deposit. You can access your account anytime via the mobile app or at chime.com.\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Receive Your Virtual Debit Card\u2028\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"After enrollment, you can add your virtual debit card to your wallet. If you would like a physical card, you can request one in the app.\u2028\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Read our \",\"marks\":[],\"data\":{}},{\"nodeType\":\"hyperlink\",\"data\":{\"uri\":\"https://www.chime.com/blog/\"},\"content\":[{\"nodeType\":\"text\",\"value\":\"blog\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"text\",\"value\":\" for more information on how to open up your account through Chime, manage your money with our mobile app, and take advantage of our user-friendly features.\",\"marks\":[],\"data\":{}}]}]},\"links\":{\"entries\":{\"inline\":[],\"hyperlink\":[]}}},\"sectionName\":null},{\"sys\":{\"id\":\"6OYbq8ptwq70UtVj8BPLyH\"},\"accordionLabelRte\":{\"json\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Where can I find a fee-free ATM?\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"links\":{\"entries\":{\"inline\":[]}}},\"accordionCopy\":{\"json\":{\"nodeType\":\"document\",\"data\":{},\"content\":[{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Chime has access to more than \",\"marks\":[],\"data\":{}},{\"nodeType\":\"embedded-entry-inline\",\"data\":{\"target\":{\"sys\":{\"id\":\"5NZ5nVmvbLtbBaCwyGyIPh\"}}},\"content\":[]},{\"nodeType\":\"text\",\"value\":\"\",\"marks\":[],\"data\":{}},{\"nodeType\":\"embedded-entry-inline\",\"data\":{\"target\":{\"sys\":{\"id\":\"3bDTdODREHN4gdSQeREa1V\"}}},\"content\":[]},{\"nodeType\":\"text\",\"value\":\"  nationwide at stores like Walgreens\",\"marks\":[],\"data\":{}},{\"nodeType\":\"text\",\"value\":\"®\",\"marks\":[{\"type\":\"superscript\"}],\"data\":{}},{\"nodeType\":\"text\",\"value\":\", 7-Eleven\",\"marks\":[],\"data\":{}},{\"nodeType\":\"text\",\"value\":\"®\",\"marks\":[{\"type\":\"superscript\"}],\"data\":{}},{\"nodeType\":\"text\",\"value\":\", CVS Pharmacy\",\"marks\":[],\"data\":{}},{\"nodeType\":\"text\",\"value\":\"®\",\"marks\":[{\"type\":\"superscript\"}],\"data\":{}},{\"nodeType\":\"text\",\"value\":\", and Circle K. You can find Chime ATMs in the app or with the \",\"marks\":[],\"data\":{}},{\"nodeType\":\"entry-hyperlink\",\"data\":{\"target\":{\"sys\":{\"id\":\"5hm14bwvwa3KV5MXvmwRz2\"}}},\"content\":[{\"nodeType\":\"text\",\"value\":\"ATM Finder\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"text\",\"value\":\" on Chime’s website.\",\"marks\":[],\"data\":{}}]}]},\"links\":{\"entries\":{\"inline\":[{\"sys\":{\"id\":\"5NZ5nVmvbLtbBaCwyGyIPh\"},\"__typename\":\"Shortcode\",\"shortCodeValue\":{\"json\":{\"nodeType\":\"document\",\"data\":{},\"content\":[{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"\",\"marks\":[],\"data\":{}},{\"nodeType\":\"hyperlink\",\"data\":{\"uri\":\"https://www.chime.com/blog/how-to-find-an-atm-near-me-for-chime/\"},\"content\":[{\"nodeType\":\"text\",\"value\":\"47,000 fee-free ATMs\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"text\",\"value\":\"\",\"marks\":[],\"data\":{}}]}]}}},{\"sys\":{\"id\":\"3bDTdODREHN4gdSQeREa1V\"},\"__typename\":\"Disclosure\",\"copy\":{\"json\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Out-of-network ATM withdrawal and over the counter advance fees may apply except at FCTI\",\"nodeType\":\"text\"},{\"data\":{},\"marks\":[{\"type\":\"superscript\"}],\"value\":\"®\",\"nodeType\":\"text\"},{\"data\":{},\"marks\":[],\"value\":\" ATMs in a 7-Eleven\",\"nodeType\":\"text\"},{\"data\":{},\"marks\":[{\"type\":\"superscript\"}],\"value\":\"®\",\"nodeType\":\"text\"},{\"data\":{},\"marks\":[],\"value\":\" or Speedway, or any Allpoint\",\"nodeType\":\"text\"},{\"data\":{},\"marks\":[{\"type\":\"superscript\"}],\"value\":\"®\",\"nodeType\":\"text\"},{\"data\":{},\"marks\":[],\"value\":\" or Visa\",\"nodeType\":\"text\"},{\"data\":{},\"marks\":[{\"type\":\"superscript\"}],\"value\":\"®\",\"nodeType\":\"text\"},{\"data\":{},\"marks\":[],\"value\":\" Plus Alliance ATM participating in the Allpoint network.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"links\":{\"entries\":{\"inline\":[]}}},\"symbol\":null}],\"hyperlink\":[{\"__typename\":\"Page\",\"sys\":{\"id\":\"5hm14bwvwa3KV5MXvmwRz2\"},\"slug\":\"online-banking/atms/\"}]}}},\"sectionName\":null},{\"sys\":{\"id\":\"5Gt8b6u5CuEHbtL7a5Erld\"},\"accordionLabelRte\":{\"json\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Does Chime require a credit check to open an account online?\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"links\":{\"entries\":{\"inline\":[]}}},\"accordionCopy\":{\"json\":{\"nodeType\":\"document\",\"data\":{},\"content\":[{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Chime does not require a credit check to open an online account. We provide services that are inclusive of all Americans. This includes those who struggle with bad credit history but are still looking for checking or savings accounts they can open and use entirely online with no opening deposit required.\",\"marks\":[],\"data\":{}}]}]},\"links\":{\"entries\":{\"inline\":[],\"hyperlink\":[]}}},\"sectionName\":null},{\"sys\":{\"id\":\"5we4kejJX6Qay51bEPWMbb\"},\"accordionLabelRte\":{\"json\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"What banks partner with Chime?\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"links\":{\"entries\":{\"inline\":[]}}},\"accordionCopy\":{\"json\":{\"nodeType\":\"document\",\"data\":{},\"content\":[{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Chime is a financial technology company that offers banking services through two banking partners: The Bancorp Bank, N.A. and Stride Bank, N.A., Members FDIC. Because Chime partners with these banks, your funds are FDIC-insured through The Bancorp Bank, N.A., or Stride Bank, N.A.\",\"marks\":[],\"data\":{}},{\"nodeType\":\"text\",\"value\":\"§\",\"marks\":[{\"type\":\"superscript\"}],\"data\":{}}]}]},\"links\":{\"entries\":{\"inline\":[],\"hyperlink\":[]}}},\"sectionName\":null},{\"sys\":{\"id\":\"js0YNWDcI7T3kE78wx6Dm\"},\"accordionLabelRte\":{\"json\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"How do I deposit money into my Chime account?\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"links\":{\"entries\":{\"inline\":[]}}},\"accordionCopy\":{\"json\":{\"nodeType\":\"document\",\"data\":{},\"content\":[{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"When you sign up for Chime, you can easily move money into your account online. Just link an external bank account to set up a transfer. To continue to get money in your Chime account, set up direct deposit from your employer or payroll provider.\u2028\u2028\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"You can deposit cash\",\"marks\":[],\"data\":{}},{\"nodeType\":\"embedded-entry-inline\",\"data\":{\"target\":{\"sys\":{\"id\":\"2xBnbBvcp2pQRoAWQUchNN\"}}},\"content\":[]},{\"nodeType\":\"text\",\"value\":\" into your Chime Account at over \",\"marks\":[],\"data\":{}},{\"nodeType\":\"embedded-entry-inline\",\"data\":{\"target\":{\"sys\":{\"id\":\"3hLnXll6Me8alO9z8mon6U\"}}},\"content\":[]},{\"nodeType\":\"text\",\"value\":\" retail locations with our cash deposit partners. The retailer that receives your cash will be responsible to transfer the funds for deposit into your Chime Account.\u2028\u2028\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Still have questions? Read our \",\"marks\":[],\"data\":{}},{\"nodeType\":\"hyperlink\",\"data\":{\"uri\":\"https://www.chime.com/blog/how-to-move-money-into-chime/\"},\"content\":[{\"nodeType\":\"text\",\"value\":\"full guide\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"text\",\"value\":\" on how to move money into Chime.\",\"marks\":[],\"data\":{}}]}]},\"links\":{\"entries\":{\"inline\":[{\"sys\":\"$6a:props:children:props:initialDisclosures:12:sys\",\"__typename\":\"Disclosure\",\"copy\":\"$6a:props:children:props:initialDisclosures:12:copy\",\"symbol\":null},{\"sys\":{\"id\":\"3hLnXll6Me8alO9z8mon6U\"},\"__typename\":\"Shortcode\",\"shortCodeValue\":{\"json\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"100,000\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"}}}],\"hyperlink\":[]}}},\"sectionName\":null},{\"sys\":{\"id\":\"7qok8r2c7JK5PsxrMtVSa0\"},\"accordionLabelRte\":{\"json\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Are Chime Account Deposits FDIC insured?\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"links\":{\"entries\":{\"inline\":[]}}},\"accordionCopy\":{\"json\":{\"nodeType\":\"document\",\"data\":{},\"content\":[{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Your funds are insured up to the standard maximum deposit insurance amount of up to $250,000 through our partner banks, Stride Bank, N.A. or The Bancorp Bank, N.A., Members FDIC.\",\"marks\":[],\"data\":{}},{\"nodeType\":\"text\",\"value\":\"§\",\"marks\":[{\"type\":\"superscript\"}],\"data\":{}},{\"nodeType\":\"text\",\"value\":\" \",\"marks\":[],\"data\":{}},{\"nodeType\":\"text\",\"value\":\"Chime itself is not FDIC-insured; The Bancorp Bank, N.A. and Stride Bank, N.A. are the FDIC-insured members. Deposit insurance covers the failure of an insured bank. Certain conditions must be satisfied for pass-through deposit insurance coverage to apply.\",\"marks\":[],\"data\":{}}]}]},\"links\":{\"entries\":{\"inline\":[],\"hyperlink\":[]}}},\"sectionName\":null},{\"sys\":{\"id\":\"3euGT3jZd4JKp6F9BidU1s\"},\"accordionLabelRte\":{\"json\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Where can I go to add money to my Chime debit card?\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"links\":{\"entries\":{\"inline\":[]}}},\"accordionCopy\":{\"json\":{\"nodeType\":\"document\",\"data\":{},\"content\":[{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"You can add money to your Chime Checking Account by making a fee-free cash deposit at any Walgreens location nationwide. And it’s not just Walgreens – for a fee, you can deposit cash into your Chime account at more than \",\"marks\":[],\"data\":{}},{\"nodeType\":\"embedded-entry-inline\",\"data\":{\"target\":{\"sys\":{\"id\":\"2MMOW36opXffK3bsAuKWcn\"}}},\"content\":[]},{\"nodeType\":\"text\",\"value\":\" retailers across the country.\",\"marks\":[],\"data\":{}}]},{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"You can also fund your debit card with direct deposit, mobile check deposit,\",\"marks\":[],\"data\":{}},{\"nodeType\":\"embedded-entry-inline\",\"data\":{\"target\":{\"sys\":{\"id\":\"1iRB3Tvb2rMbS5VxUq31RF\"}}},\"content\":[]},{\"nodeType\":\"text\",\"value\":\" instant transfers,\",\"marks\":[],\"data\":{}},{\"nodeType\":\"embedded-entry-inline\",\"data\":{\"target\":{\"sys\":{\"id\":\"K5qJUtxU5qExOFUSoqMZ4\"}}},\"content\":[]},{\"nodeType\":\"text\",\"value\":\" and bank transfers, all in the mobile app.\",\"marks\":[],\"data\":{}}]}]},\"links\":{\"entries\":{\"inline\":[{\"sys\":{\"id\":\"2MMOW36opXffK3bsAuKWcn\"},\"__typename\":\"Shortcode\",\"shortCodeValue\":{\"json\":{\"nodeType\":\"document\",\"data\":{},\"content\":[{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"85,000\",\"marks\":[],\"data\":{}}]}]}}},{\"sys\":\"$6a:props:children:props:initialDisclosures:13:sys\",\"__typename\":\"Disclosure\",\"copy\":\"$6a:props:children:props:initialDisclosures:13:copy\",\"symbol\":null},{\"sys\":\"$6a:props:children:props:initialDisclosures:14:sys\",\"__typename\":\"Disclosure\",\"copy\":\"$6a:props:children:props:initialDisclosures:14:copy\",\"symbol\":null}],\"hyperlink\":[]}}},\"sectionName\":null}]},\"tabCopy\":null}],\"sys\":{\"id\":\"7Ff30r2YHT59De7nuYnL9Q\"},\"color\":\"Primary\",\"variant\":\"$undefined\"}]]}]\n"])</script><script nonce="ZmIwOWI5YmQtZWI3Yi00ZmVlLWFkYTgtYjM2YTdiNDA5ODM4">self.__next_f.push([1,"ca:[\"$\",\"div\",null,{\"className\":\"mt-6 sm:mt-8 md:mt-12 w-full flex items-center gap-2 justify-start\",\"children\":[\"$\",\"$L33\",null,{\"sys\":{\"id\":\"5zArMekXdATEkhOBEYyV8U\"},\"href\":\"https://www.chime.com/security-and-support/security-and-control/\",\"internalPage\":null,\"target\":null,\"ctaLevel\":\"$undefined\",\"variant\":\"outline\",\"className\":\"place-self-center link-button-outline border-(--btn-outline) font-sans font-semibold flex items-center justify-center gap-2 sm:max-w-max hover:border-(--btn-outline-hover) link-button-outline border-[1.5px] py-[6.5px] px-14 rounded-md text-current hover:text-current leading-tight\",\"id\":\"$undefined\",\"testId\":\"$undefined\",\"children\":\"Learn More\"}]}]\n"])</script></body></html>