t\",\"data\":{},\"content\":[{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"“I love this banking app! No fees for overdraft, I get paid 2 days earlier. If I could give it more than 5 stars, I would.”\",\"marks\":[],\"data\":{}}]}]},\"links\":{\"entries\":{\"inline\":[],\"hyperlink\":[]}}},\"cta\":{\"sys\":{\"id\":\"6xvQbCb43tYsXWYtyKGJxs\"},\"internalPage\":null,\"label\":\"Play Store\",\"url\":\"https://play.google.com/store/apps/details/Chime_Mobile_Banking?id=com.onedebit.chime\u0026hl=en_SG\",\"target\":\"Open link in a new tab\",\"id\":null,\"class\":null},\"aspectRatio\":null,\"attributionRte\":null},{\"sys\":{\"id\":\"6sr1NSrgyfMpvEWuS5TC3J\"},\"__typename\":\"TestimonialItem\",\"media\":{\"url\":\"https://images.ctfassets.net/ao7gxs2zk32d/5jveKuqBb7LEpzosz64aC4/c099c2d06d6c9d22da85a1e5c8c3c1e9/Exclude.svg\",\"title\":\"Homepage Redesign - Reddit Testimonial Icon\",\"contentType\":\"image/svg+xml\",\"description\":\"Reddit logo in dark green.\",\"fileName\":\"Exclude.svg\",\"width\":18,\"height\":18,\"size\":1983},\"copy\":{\"json\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"“I absolutely love all Chime offers me as a Chime+ member! I receive my check two days early, who wouldn’t appreciate that? My Pay? I can access my pay early, which is super helpful for emergency situations. No overdraft fees thanks to Spot Me and it’s all so easy and hassle free.”\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"links\":{\"entries\":{\"inline\":[],\"hyperlink\":[]}}},\"cta\":{\"sys\":{\"id\":\"66FpOYftlBqFNS2ENnrf08\"},\"internalPage\":null,\"label\":\"Reddit\",\"url\":\"https://www.reddit.com/r/chimefinancial/\",\"target\":\"Open link in a new tab\",\"id\":null,\"class\":null},\"aspectRatio\":null,\"attributionRte\":null},{\"sys\":{\"id\":\"4NwuaWpUtgT5hkTik9NW4h\"},\"__typename\":\"TestimonialItem\",\"media\":{\"url\":\"https://images.ctfassets.net/ao7gxs2zk32d/4bMqgy9PuOupCeq2DDWPyC/60074121cfbb40f51956c18aa5ff29ec/apple-logo-green.svg\",\"title\":\"Homepage Redesign - Testimonial Apple Icon (Dark Green)\",\"contentType\":\"image/svg+xml\",\"description\":\"\",\"fileName\":\"apple-logo-green.svg\",\"width\":18,\"height\":22,\"size\":657},\"copy\":{\"json\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"“Awesome Spot Me that lets you overdraft without the worry of any hidden fees. My credit score went from a 610 to 755 in a year.”\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"links\":{\"entries\":{\"inline\":[],\"hyperlink\":[]}}},\"cta\":{\"sys\":{\"id\":\"5OghPK62kmq90J1LglPGGI\"},\"internalPage\":null,\"label\":\"App Store\",\"url\":\"https://apps.apple.com/us/app/chime-mobile-banking/id836215269\",\"target\":\"Open link in a new tab\",\"id\":null,\"class\":null},\"aspectRatio\":null,\"attributionRte\":null}]},\"slideColor\":{\"id\":\"d77e4e56-d326-446d-b6e1-699597995e76\",\"name\":\"Primary\",\"value\":\"#ffffff\"},\"margins\":\"Centered\",\"disclaimer\":null,\"schema\":null,\"children\":\"$undefined\"}]}]}]\n"])</script><script nonce="ZmIwOWI5YmQtZWI3Yi00ZmVlLWFkYTgtYjM2YTdiNDA5ODM4">self.__next_f.push([1,"ac:[\"$\",\"$L2e\",\"6\",{\"initialAttributes\":{\"moduleTitle\":\"app-store\",\"moduleName\":\"Open a Chime checking account in minutes.\",\"moduleIndex\":\"6\",\"moduleLocation\":\"http://www.chime.com/\",\"moduleType\":\"MediaCopy\",\"pageTitle\":\"Homepage LP - Phase 2 Redesign\",\"pageTags\":\"$77:props:children:1:props:children:0:2:props:children:1:props:children:0:props:initialAttributes:pageTags\"},\"children\":[\"$\",\"$L2f\",null,{\"exposure\":\"$undefined\",\"moduleId\":\"2HvufNJ8BoNRZJnbvyj0iC\",\"nonce\":\"ZmIwOWI5YmQtZWI3Yi00ZmVlLWFkYTgtYjM2YTdiNDA5ODM4\",\"hasPerformanceConsent\":true,\"children\":[\"$\",\"$Lc5\",null,{\"sys\":{\"id\":\"2HvufNJ8BoNRZJnbvyj0iC\"},\"__typename\":\"MediaCopy\",\"sectionName\":\"app-store\",\"variant\":\"Contained Background\",\"headline\":{\"json\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Open a Chime checking account in minutes.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"links\":{\"entries\":{\"inline\":[]}}},\"copy\":{\"json\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Download now to get started.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"links\":{\"entries\":{\"inline\":[],\"hyperlink\":[]}}},\"copyPosition\":\"Bottom\",\"color\":{\"id\":\"d77e4e56-d326-446d-b6e1-699597995e76\",\"name\":\"Primary\",\"value\":\"#ffffff\"},\"containedColor\":{\"id\":\"3e0ce6c0-8dfb-48a8-a1b0-44a0c7aa5820\",\"name\":\"Dark Gradient - Left to Right\",\"value\":\"#0d4127\"},\"alignment\":\"Media right, copy left\",\"mobileAlignment\":\"Media below copy\",\"image\":{\"sys\":{\"id\":\"3PafdtRKWnhWOfi2BQspNd\"},\"url\":\"https://images.ctfassets.net/ao7gxs2zk32d/3PafdtRKWnhWOfi2BQspNd/14fb309c35da607f9ec96f6c05cb5b21/Sign_up.webp\",\"title\":\"Chime Prime app on a smartphone. Labeled #1 Most Loved Banking App.\",\"contentType\":\"image/webp\",\"description\":\"Smartphone displaying Chime Prime banking app dashboard showing account balance, savings, cash back, and FICO score features.\",\"fileName\":\"Sign up.webp\",\"width\":2000,\"height\":2000,\"size\":337812},\"aspectRatio\":{\"value\":1},\"hyperlinkedImagesCollection\":{\"items\":[{\"image\":{\"url\":\"https://images.ctfassets.net/ao7gxs2zk32d/2thvMa9anCij8hUA2QNiA5/e150c4820e6e316d53104cd146eda523/Apple_App_Store.svg\",\"title\":\"Apple App Store\",\"contentType\":\"image/svg+xml\",\"description\":\"Apple App Store button.\",\"fileName\":\"Apple App Store.svg\",\"width\":201,\"height\":44,\"size\":9257},\"link\":\"https://apps.apple.com/us/app/chime-mobile-banking/id836215269\"},{\"image\":{\"url\":\"https://images.ctfassets.net/ao7gxs2zk32d/24yXLbQxRjl3VV8X34b4rI/fc9d0a17ad1d71b44c9f5b79c1338570/Google_Play.svg\",\"title\":\"Google Play logo\",\"contentType\":\"image/svg+xml\",\"description\":\"Google Play logo\",\"fileName\":\"Google Play.svg\",\"width\":201,\"height\":44,\"size\":10924},\"link\":\"https://play.google.com/store/apps/details?id=com.onedebit.chime\u0026hl=en\"}]},\"margins\":\"Centered\",\"mobileCopyJustification\":\"Center\",\"eyebrowAlternateLogo\":{\"url\":\"https://images.ctfassets.net/ao7gxs2zk32d/yotdxJL87qeGLqgbdb678/29b00551376d6a7ba307dc4a042c1dd1/chime_logo.svg\",\"title\":\"Chime Logo (Action Primary Green with Trademark)\",\"contentType\":\"image/svg+xml\",\"description\":\"Chime logo. \",\"fileName\":\"chime logo.svg\",\"width\":72,\"height\":21,\"size\":9792},\"headlineEyebrow\":null,\"notificationOverlay\":null,\"topRightBadge\":null,\"schema\":null,\"eyebrowText\":null,\"eyebrowChimeLogo\":null,\"notificationOverlayDesktopPosition\":null,\"cta\":null,\"sliderEntryCollection\":{\"items\":[]},\"children\":\"$undefined\"}]}]}]\n"])</script><script nonce="ZmIwOWI5YmQtZWI3Yi00ZmVlLWFkYTgtYjM2YTdiNDA5ODM4">self.__next_f.push([1,"c6:Tff4,"])</script><script nonce="ZmIwOWI5YmQtZWI3Yi00ZmVlLWFkYTgtYjM2YTdiNDA5ODM4">self.__next_f.push([1,"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Is Chime an online bank?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Chime is not a bank, but a financial technology company. We partner with The Bancorp Bank, N.A. and Stride Bank, N.A., Members FDIC, which are both FDIC-insured.\"}},{\"@type\":\"Question\",\"name\":\"How do you open an account online through Chime?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Apply in minutes on chime.com or download the Chime mobile app (Google Play or Apple App Store).You must be at least 18 years old, and you’ll need your Social Security number, email address, and a valid U.S. address.Set Up Banking\u2028Once approved, you can connect your existing bank account to transfer funds or set up direct deposit. You can access your account anytime via the mobile app or at chime.com.Receive Your Virtual Debit Card\u2028After enrollment, you can add your virtual debit card to your wallet. If you would like a physical card, you can request one in the app.\u2028Read our blog for more information on how to open up your account through Chime, manage your money with our mobile app, and take advantage of our user-friendly features.\"}},{\"@type\":\"Question\",\"name\":\"Where can I find a fee-free ATM?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Chime has access to more than   nationwide at stores like Walgreens®, 7-Eleven®, CVS Pharmacy®, and Circle K. You can find Chime ATMs in the app or with the ATM Finder on Chime’s website.\"}},{\"@type\":\"Question\",\"name\":\"Does Chime require a credit check to open an account online?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Chime does not require a credit check to open an online account. We provide services that are inclusive of all Americans. This includes those who struggle with bad credit history but are still looking for checking or savings accounts they can open and use entirely online with no opening deposit required.\"}},{\"@type\":\"Question\",\"name\":\"What banks partner with Chime?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Chime is a financial technology company that offers banking services through two banking partners: The Bancorp Bank, N.A. and Stride Bank, N.A., Members FDIC. Because Chime partners with these banks, your funds are FDIC-insured through The Bancorp Bank, N.A., or Stride Bank, N.A.§\"}},{\"@type\":\"Question\",\"name\":\"How do I deposit money into my Chime account?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"When you sign up for Chime, you can easily move money into your account online. Just link an external bank account to set up a transfer. To continue to get money in your Chime account, set up direct deposit from your employer or payroll provider.\u2028\u2028You can deposit cash into your Chime Account at over  retail locations with our cash deposit partners. The retailer that receives your cash will be responsible to transfer the funds for deposit into your Chime Account.\u2028\u2028Still have questions? Read our full guide on how to move money into Chime.\"}},{\"@type\":\"Question\",\"name\":\"Are Chime Account Deposits FDIC insured?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Your funds are insured up to the standard maximum deposit insurance amount of up to $250,000 through our partner banks, Stride Bank, N.A. or The Bancorp Bank, N.A., Members FDIC.§ Chime itself is not FDIC-insured; The Bancorp Bank, N.A. and Stride Bank, N.A. are the FDIC-insured members. Deposit insurance covers the failure of an insured bank. Certain conditions must be satisfied for pass-through deposit insurance coverage to apply.\"}},{\"@type\":\"Question\",\"name\":\"Where can I go to add money to my Chime debit card?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"You can add money to your Chime Checking Account by making a fee-free cash deposit at any Walgreens location nationwide. And it’s not just Walgreens – for a fee, you can deposit cash into your Chime account at more than  retailers across the country.You can also fund your debit card with direct deposit, mobile check deposit, instant transfers, and bank transfers, all in the mobile app.\"}}]}"])</script><script nonce="ZmIwOWI5YmQtZWI3Yi00ZmVlLWFkYTgtYjM2YTdiNDA5ODM4">self.__next_f.push([1,"ad:[\"$\",\"$L2e\",\"7\",{\"initialAttributes\":{\"moduleTitle\":\"faqs\",\"moduleName\":\"FAQs\",\"moduleIndex\":\"7\",\"moduleLocation\":\"http://www.chime.com/\",\"moduleType\":\"Faq\",\"pageTitle\":\"Homepage LP - Phase 2 Redesign\",\"pageTags\":\"$77:props:children:1:props:children:0:2:props:children:1:props:children:0:props:initialAttributes:pageTags\"},\"children\":[\"$\",\"$L2f\",null,{\"e