h (_) {\n    // Observability must never throw inside the dispatcher.\n  }\n};\n\nwindow.OptanonWrapper = () =\u003e {\n  const raw = typeof window.OnetrustActiveGroups === 'string' ? window.OnetrustActiveGroups : '';\n  const optanon = window.__CHIME_OPTANON__;\n  const state = optanon.state;\n\n  // OneTrust fires the wrapper on every consent dialog interaction; skip the\n  // dispatch when nothing actually changed so subscribers don't see duplicates.\n  if (state.lastActiveGroupsString === raw) return;\n\n  const previousGroups = state.lastActiveGroups || [];\n  const isFirstDispatch = state.lastActiveGroupsString === undefined;\n  state.lastActiveGroupsString = raw;\n  state.lastActiveGroups = raw\n    .split(',')\n    .map(s =\u003e s.trim())\n    .filter(Boolean);\n\n  // Emit once per page load so Datadog dashboards have a denominator for the\n  // revoke-rate metric (`consentRevoked / consentResolved`) and can chart\n  // per-category consent grant rates by grouping on `@activeGroups`.\n  if (isFirstDispatch) {\n    sendConsentBeacon({\n      source: 'onetrust-consent',\n      event: 'consentResolved',\n      activeGroups: state.lastActiveGroups,\n    });\n  }\n\n  // Surface mid-session opt-outs (categories the user removed since the last\n  // dispatch) so Datadog dashboards can chart revocations by category.\n  const revokedCategories = previousGroups.filter(g =\u003e !state.lastActiveGroups.includes(g));\n  if (revokedCategories.length \u003e 0) {\n    sendConsentBeacon({\n      source: 'onetrust-consent',\n      event: 'consentRevoked',\n      revokedCategories,\n      activeGroups: state.lastActiveGroups,\n      previousActiveGroups: previousGroups,\n    });\n  }\n\n  const handlers = optanon.handlers.slice();\n  for (const handler of handlers) {\n    try {\n      // Pass a copy so handlers can't mutate the shared snapshot.\n      handler(state.lastActiveGroups.slice());\n    } catch (err) {\n      const message = err instanceof Error ? `${err.name}: ${err.message}` : String(err);\n      const stack = err instanceof Error ? err.stack : undefined;\n      sendConsentBeacon({\n        source: 'onetrust-consent',\n        event: 'handlerError',\n        phase: 'dispatch',\n        activeGroups: state.lastActiveGroups,\n        message,\n        stack,\n      });\n    }\n  }\n};\n"])</script><script nonce="ZmIwOWI5YmQtZWI3Yi00ZmVlLWFkYTgtYjM2YTdiNDA5ODM4">self.__next_f.push([1,"14:[[\"$\",\"script\",null,{\"id\":\"onetrust-wrapper\",\"className\":\"optanon-category-C0001\",\"nonce\":\"ZmIwOWI5YmQtZWI3Yi00ZmVlLWFkYTgtYjM2YTdiNDA5ODM4\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"$18\"}}],\"$L19\",\"$L1a\",\"$L1b\"]\n15:[\"$\",\"script\",null,{\"id\":\"segment-config\",\"className\":\"optanon-category-C0001\",\"nonce\":\"ZmIwOWI5YmQtZWI3Yi00ZmVlLWFkYTgtYjM2YTdiNDA5ODM4\",\"suppressHydrationWarning\":true,\"dangerouslySetInnerHTML\":{\"__html\":\"window.__CHIME_CONFIG__ = window.__CHIME_CONFIG__ || {};window.__CHIME_CONFIG__.segmentWriteKey = \\\"89nms3o7yr\\\";\"}}]\n16:[\"$\",\"body\",null,{\"className\":\"antialiased\",\"children\":[[\"$\",\"$L1c\",null,{}],[\"$\",\"$L1d\",null,{}],[\"$\",\"$L1e\",null,{}],[\"$\",\"$L1f\",null,{\"experiences\":[],\"audiences\":[],\"mode\":\"server\",\"children\":[false,[\"$\",\"$L20\",null,{\"children\":[[\"$\",\"$L21\",null,{}],[\"$\",\"$L22\",null,{}],[\"$\",\"$L23\",null,{\"features\":\"$24\",\"children\":[\"$\",\"$L25\",null,{\"children\":[\"$\",\"$L3\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L4\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":[\"$L26\",[]],\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]}]}]]}]]}],\"$L27\"]}]\n17:[\"$\",\"$L28\",null,{}]\n19:[\"$\",\"script\",null,{\"className\":\"optanon-category-C0001\",\"nonce\":\"ZmIwOWI5YmQtZWI3Yi00ZmVlLWFkYTgtYjM2YTdiNDA5ODM4