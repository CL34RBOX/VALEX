  console.log('[FAST ANALYTICS] SDK inlined, waiting for Track and analyticsHandler...');
  
  // Shared cookie name for both analytics events
  var firstPageViewedCookie = 'fpViewed';
  
  // Check cookie once at the start - this is the source of truth
  var shouldFireEvents = !getCookieValue(firstPageViewedCookie);
  
  // Expose for the Segment script to use
  window.shouldFireFirstPageEvents = shouldFireEvents;
  
  if (shouldFireEvents && true) {
    // Set cookie immediately to prevent duplicates on page refresh during polling.
    // Gated on OneTrust Functional (C0003) consent — the boolean is computed
    // server-side because this script runs before OneTrust hydrates.
    const cookieDomain = window.getEnv() === 'production' ? '; domain=.chime.com' : '';
    document.cookie = firstPageViewedCookie + '=true; path=/; SameSite=Lax' + cookieDomain;
  }
  
  // Poll for SDK to be ready
  let attempts = 0;
  const maxAttempts = 3000;
  
  function checkSDKReady() {
    attempts++;
    
    if (window.Track && window.analyticsHandler) {
      console.log('[FAST ANALYTICS] SDK ready!');
      
      if (shouldFireEvents) {
        // OneTrust Performance (C0002) gate. Mirrors parseOptanonConsentGroups
        // in libs/oneTrust/parseOptanonConsent.ts: split on '&' first, then
        // decode only the groups= value once. Decoding the whole cookie up
        // front and decoding again on the slice would double-decode any '%25'
        // sequences and throw on the second pass.
        //
        // If the OptanonConsent cookie is set, it is the source of truth —
        // cookie present without C0002:1 (including missing/malformed groups)
        // means opted out. Only fall back to GPC when no banner choice exists.
        function hasPerformanceConsent() {
          var optanonRaw = getCookieValue('OptanonConsent');
          if (optanonRaw) {
            var groupsSegment;
            var parts = optanonRaw.split('&');
            for (var i = 0; i < parts.length; i++) {
              if (parts[i].indexOf('groups=') === 0) {
                groupsSegment = parts[i];
                break;
              }
            }
            if (!groupsSegment) return false;
            try {
              var groups = decodeURIComponent(groupsSegment.slice('groups='.length));
              // Split each "Cxxxx:N" entry on ':' and trim both pieces — matches
              // parseOptanonConsentGroups so e.g. "C0002 : 1" still counts as
              // granted, the way the shared parser does it.
              return groups.split(',').some(function (entry) {
                var pair = entry.split(':');
                return pair.length === 2 && pair[0].trim() === 'C0002' && pair[1].trim() === '1';
              });
            } catch (error) {
              // Malformed URL-encoding in the cookie — treat as opted out, same
              // as parseOptanonConsentGroups in libs/oneTrust/parseOptanonConsent.ts.
              return false;
            }
          }
          if (navigator.globalPrivacyControl === true) {
            return false;
          }
          return true;
        }

        if (hasPerformanceConsent()) {
          // Fire the event ASAP!
          try {
            window.analyticsHandler.trackEvent(window.Track.WebActionTriggered, {
              unique_id: 'first_entry_point',
            });
            console.log('[FAST ANALYTICS] ✅ first_entry_point event fired successfully!');
          } catch (error) {
            console.error('[FAST ANALYTICS] ❌ Failed to fire event:', error);
          }
        }
      } else {
        console.log('[FAST ANALYTICS] Event already fired (cookie existed)');
      }
    } else if (attempts < maxAttempts) {
      setTimeout(checkSDKReady, 1); // Check every 1ms for fastest response
    } else {
      console.error('[FAST ANALYTICS] ❌ SDK not ready after', maxAttempts, 'attempts');
    }
  }
  
  checkSDKReady();
})();
            </script><script id="onetrust-wrapper" class="optanon-category-C0001" nonce="ZmIwOWI5YmQtZWI3Yi00ZmVlLWFkYTgtYjM2YTdiNDA5ODM4">/**
 * Defines window.OptanonWrapper, the single global callback OneTrust invokes
 * on initial load and on every consent change. Acts as a dispatcher: feature
 * modules register handlers through libs/oneTrust (onConsentChange), and this
 * wrapper fans the active groups out to all of them.
 *
 * Must execute before the OneTrust SDK so the global exists when the SDK first
 * looks for it. Inlined into the HTML by components/oneTrust.tsx via
 * readFileSync — kept as a real .js source for editor support and isolation
 * from the React tree.
 *
 * Keep this file tiny and dependency-free. Subscriber logic belongs in
 * libs/oneTrust.ts and feature-specific modules, not here.
 */
window.__CHIME_OPTANON__ ??= { handlers: [], state: {} };

// Inline counterpart of logConsentEvent (libs/oneTrust/observability.ts) —
// this file is inlined into HTML before any module loads and can't import.
// Keep the shape and transport in sync with that helper.
const sendConsentBeacon = payload => {
  try {
    const body = JSON.stringify(payload);
    if (typeof navigator !== 'undefined' && typeof navigator.sendBeacon === 'function') {
      if (navigator.sendBeacon('/api/onetrust-event', body)) return;
    }
    if (typeof fetch === 'function') {
      fetch('/api/onetrust-event', { method: 'POST', body, keepalive: true }).catch(() => {});
    }
  } catch (_) {
    // Observability must never throw inside the dispatcher.
  }
};

window.OptanonWrapper = () => {
  const raw = typeof window.OnetrustActiveGroups === 'string' ? window.OnetrustActiveGroups : '';
  const optanon = window.__CHIME_OPTANON__;
  const state = optanon.state;

  // OneTrust fires the wrapper on every consent dialog interaction; skip the
  // dispatch when nothing actually changed so subscribers don't see duplicates.
  if (state.lastActiveGroupsString === raw) return;

  const previousGroups = state.lastActiveGroups || [];
  const isFirstDispatch = state.lastActiveGroupsString === undefined;
  state.lastActiveGroupsString = raw;
  state.lastActiveGroups = raw
    .split(',')
    .map(s => s.trim())
    .filter(Boolean);

  // Emit once per page load so Datadog dashboards have a denominator for the
  // revoke-rate metric (`consentRevoked / consentResolved`) and can chart
  // per-category consent grant rates by grouping on `@activeGroups`.
  if (isFirstDispatch) {
    sendConsentBeacon({
      source: 'onetrust-consent',
      event: 'consentResolved',
      activeGroups: state.lastActiveGroups,
    });
  }

  // Surface mid-session opt-outs (categories the user removed since the last
  // dispatch) so Datadog dashboards can chart revocations by category.
  const revokedCategories = previousGroups.filter(g => !state.lastActiveGroups.includes(g));
  if (revokedCategories.length > 0) {
    sendConsentBeacon({
      source: 'onetrust-consent',
      event: 'consentRevoked',
      revokedCategories,
      activeGroups: state.lastActiveGroups,
      previousActiveGroups: previousGroups,
    });
  }

  const handlers = optanon.handlers.slice();
  for (const handler of handlers) {
    try {
      // Pass a copy so handlers can't mutate the shared snapshot.
      handler(state.lastActiveGroups.slice());
    } catch (err) {
      const message = err instanceof Error ? `${err.name}: ${err.message}` : String(err);
      const stack = err instanceof Error ? err.stack : undefined;
      sendConsentBeacon({
        source: 'onetrust-consent',
        event: 'handlerError',
        phase: 'dispatch',
        activeGroups: state.lastActiveGroups,
        message,
        stack,
      });
    }
  }
};
