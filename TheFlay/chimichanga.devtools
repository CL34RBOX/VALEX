(function() {
  console.log('[FAST ANALYTICS] Starting - BEFORE React hydration');

  // Cookie handling function
  function getCookieValue(name) {
    const value = '; ' + document.cookie;
    const parts = value.split('; ' + name + '=');
    if (parts.length === 2) {
      return parts.pop().split(';').shift();
    }
    return '';
  }

  // Set up globals needed by analytics SDK
  window.getCookieValue = getCookieValue;

  // Keep Segment's local storage identity aligned with the server-set cookie before Segment initializes.
  // Segment stores localStorage values as JSON-quoted strings (e.g., '"uuid"').
  var segmentAnonymousId = getCookieValue('ajs_anonymous_id');
  if (segmentAnonymousId) {
    try {
      localStorage.setItem('ajs_anonymous_id', JSON.stringify(segmentAnonymousId));
    } catch (error) {
      console.warn('[FAST ANALYTICS] Could not sync Segment anonymous ID:', error);
    }
  }
  
  // Performance metrics (required by SDK)
  window.fcp = window.fcp || 0;
  window.lcp = window.lcp || 0;
  
  // Environment detection for SDK
  window.getEnv = function() {
    const hostname = window.location.hostname;
    if (hostname === 'www.chime.com' || hostname === 'chime.com') {
      return 'production';
    } else {
      return 'qa';
    }
  };

  // DataDog fallbacks
  window.addDataDogError = window.addDataDogError || function(msg, ctx) { console.error('[DD Error]', msg, ctx); };
  window.addDataDogAction = window.addDataDogAction || function(msg, ctx) { console.log('[DD Action]', msg, ctx); };

