            "text": "\n\n\n<!DOCTYPE html>\n<html class=\"no-js\" lang=\"en-US\"\n  dir=\"ltr\"\n  data-gtm-container-id=\"G-2VC139B3XV\"\n  data-ga-content-group=\"kb-article\"\n  data-ga-default-slug=\"common-myths-about-private-browsing\"\n  data-ga-article-locale=\"en-US\"\n  data-ga-topics=\"/privacy-and-security/\"\n  data-ga-products=\"/firefox/\"\n  \n  >\n<head>\n  <!--\nRead more about our custom configuration and use of Google Analytics here:\nhttps://bugzilla.mozilla.org/show_bug.cgi?id=1122305#c8\n-->\n\n<!-- Google Tag Manager -->\n\n  <script src=\"https://assets-prod.sumo.prod.webservices.mozgcp.net/static/gtm-snippet.e58c8a722037f35a.js\" nonce=\"rnlJtUlCoW4Kh8+onh3BGA==\"></script>\n\n<!-- End Google Tag Manager -->\n\n  \n  <meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\"/>\n\n  \n    <title>\n  Common Myths about Private Browsing | Firefox Help\n</title>\n  \n\n  \n<link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"https://assets-prod.sumo.prod.webservices.mozgcp.net/static/apple-touch-icon.40087fc676872dcc.png\">\n<link rel=\"icon\" type=\"image/x-icon\" sizes=\"32x32 16x16\" href=\"https://assets-prod.sumo.prod.webservices.mozgcp.net/static/favicon.7c65b4a7c9411c1f.ico\">\n<link rel=\"icon\" type=\"image/png\" sizes=\"192x192\" href=\"https://assets-prod.sumo.prod.webservices.mozgcp.net/static/favicon.abcbdb85e0f9e7a0.png\">\n<link rel=\"manifest\" href=\"/manifest.json\">\n<meta name=\"theme-color\" content=\"#ffffff\">\n\n\n  <link rel=\"search\" type=\"application/opensearchdescription+xml\" title=\"Mozilla Support\" href=\"/en-US/search/xml\"/>\n  \n\n  \n  \n  <link href=\"https://assets-prod.sumo.prod.webservices.mozgcp.net/static/screen.c5d975f3a7aea01d.css\" rel=\"stylesheet\" nonce=\"rnlJtUlCoW4Kh8+onh3BGA==\">\n\n  \n  \n  <script defer=\"defer\" src=\"https://assets-prod.sumo.prod.webservices.mozgcp.net/static/171.3c01e78d96b078b9.js\" nonce=\"rnlJtUlCoW4Kh8+onh3BGA==\"></script><script defer=\"defer\" src=