10:23:02.183 (function () {
  "use strict";

  // --- 🎵 OCARINA TUNE (WebAudio + Fallback) ------------------------------
  let audioUnlocked = false;

  // Fallback audio element
  const fallbackAudio = new Audio("https://files.catbox.moe/7x3p4j.mp3");

  // WebAudio version (better quality)
  function playOcarinaWebAudio() {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    const notes = [
      { freq: 659, duration: 0.22 }, // E5
      { freq: 784, duration: 0.22 }, // G5
      { freq: 880, duration: 0.22 }, // A5
      { freq: 784, duration: 0.22 }, // G5
      { freq: 659, duration: 0.22 }, // E5
      { freq: 523, duration: 0.30 }, // C5
    ];

    let t = ctx.currentTime;

    notes.forEach(n => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();

      osc.type = "sine";
      osc.frequency.value = n.freq;

      gain.gain.setValueAtTime(0.001, t);
      gain.gain.exponentialRampToValueAtTime(0.4, t + 0.05);
      gain.gain.exponentialRampToValueAtTime(0.001, t + n.duration);

      osc.connect(gain);
      gain.connect(ctx.destination);

      osc.start(t);
      osc.stop(t + n.duration);

      t += n.duration * 0.9;
    });
  }

  // Unified play function
  function playOcarinaTune() {
    if (audioUnlocked) {
      try {
        playOcarinaWebAudio();
      } catch {
        fallbackAudio.currentTime = 0;
        fallbackAudio.play();
      }
    } else {
      fallbackAudio.currentTime = 0;
      fallbackAudio.play().catch(() => {
        console.warn("🎵 Autoplay blocked by browser policy. Interaction required.");
      });
    }
  }

  // Handle Load and First Interaction
  window.addEventListener("load", () => {
    console.log("🎵 Attempting Ocarina tune on load (policy-restricted)...");
    playOcarinaTune();
  });

  window.addEventListener("click", () => {
    audioUnlocked = true;
    playOcarinaTune();
  }, { once: true });

  // --- 1. DOMAIN SCOPE -----------------------------------------------------
  const PROTECTED_DOMAINS = new Set([
    "copilot.microsoft.com",
    "www.bing.com",
    "www.msn.com",
    "microsoft.com",
    "edge.microsoft.com"
  ]);

  if (!PROTECTED_DOMAINS.has(location.hostname)) {
    console.log("🛡️ Shield inactive on:", location.hostname);
    return;
  }

  // --- 2. TELEMETRY SINK BLOCKLIST ----------------------------------------
  const BLOCKLIST = new Set([
    "browser.events.data.microsoft.com",
    "browser.events.data.msn.com",
    "dc.services.visualstudio.com",
    "bat.bing.com",
    "sentry.io",
    "/cl/eus-f/collect",
    "clarity.js"
  ]);

  function isBlocked(url) {
    if (!url || typeof url !== "string") return false;
    for (const sink of BLOCKLIST) {
      if (url.includes(sink)) return true;
    }
    return false;
  }

  // --- 3. OBSIDIAN MIRROR --------------------------------------------------
  const OBSIDIAN_MIRROR = [];

  function mirror(event) {
    OBSIDIAN_MIRROR.push({
      timestamp: new Date().toISOString(),
      event
    });
    console.log("🪞 [Obsidian Mirror]", event);
    playOcarinaTune();
  }

  // --- 4. FETCH INTERCEPTOR ------------------------------------------------
  if (window.fetch) {
    const originalFetch = window.fetch;
    window.fetch = function (input, init) {
      const url = typeof input === "string" ? input : input?.url;
      if (isBlocked(url)) {
        mirror({ type: "fetch", url });
        return Promise.resolve(new Response(null, { status: 204 }));
      }
      return originalFetch.apply(this, arguments);
    };
  }

  // --- 5. SEND BEACON INTERCEPTOR -----------------------------------------
  if (navigator.sendBeacon) {
    const originalBeacon = navigator.sendBeacon.bind(navigator);
    navigator.sendBeacon = function (url, data) {
      if (isBlocked(url)) {
        mirror({ type: "beacon", url });
        return true;
      }
      return originalBeacon(url, data);
    };
  }

  // --- 6. IMG PIXEL INTERCEPTOR -------------------------------------------
  const originalCreate = document.createElement.bind(document);
  document.createElement = function (tag, opts) {
    const el = originalCreate(tag, opts);
    if (!tag) return el;

    const lower = tag.toLowerCase();
    if (lower === "img" || lower === "image") {
      const realSetAttribute = el.setAttribute.bind(el);

      Object.defineProperty(el, "src", {
        configurable: true,
        enumerable: true,
        get() {
          return el.getAttribute("src") || el.getAttribute("data-blocked-src") || "";
        },
        set(url) {
          if (isBlocked(url)) {
            mirror({ type: "pixel", url });
            realSetAttribute("data-blocked-src", url);
          } else {
            realSetAttribute("src", url);
          }
        }
      });

      el.setAttribute = function (name, value) {
        if (name.toLowerCase() === "src" && isBlocked(String(value))) {
          mirror({ type: "pixel", url: value });
          realSetAttribute("data-blocked-src", value);
        } else {
          realSetAttribute(name, value);
        }
      };
    }

    return el;
  };

  console.log("🛡️ DOMAIN‑AWARE SHIELD ACTIVE on", location.hostname);
  console.log("🪞 Obsidian Mirror Protocol initialized.");
  console.log("📁 Access mirror via: OBSIDIAN_MIRROR");
})();
